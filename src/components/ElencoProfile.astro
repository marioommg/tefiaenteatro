  }

  /* Progressive reveal */
  .reveal-on-scroll {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.6s ease,
      transform 0.6s ease;
  }
  .reveal-on-scroll.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* Sección de todos los actores */
  .all-actors-section {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }
  .all-actors-section h2 {
    font-size: 1.5rem;
    margin: 0 0 1rem 0;
    text-align: center;
  }
  .actors-grid-wrapper {
    position: relative;
    max-height: 320px;
    overflow: hidden; /* evita scrollbar horizontal por redondeos/box-shadows */
    /* Crear gutter interno sin crecer el ancho total */
    margin-left: -8px;
    margin-right: -8px;
    padding-left: 8px;
    padding-right: 8px;
    padding-top: 3px;
    transition: max-height 0.5s ease;
  }
  .actors-grid-wrapper.expanded {
    max-height: none;
  }
  .actors-grid-wrapper::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    height: 100px;
    background: linear-gradient(
      to bottom,
      transparent,
      var(--bg-color, #0a0a0a)
    );
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .actors-grid-wrapper.expanded::after {
    opacity: 0;
  }
  .actors-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    gap: clamp(0.75rem, 2vw, 1rem);
    overflow: visible; /* permite que sombras no generen scroll en el wrapper */
  }
  .expand-btn {
    display: block;
    margin: 1rem auto 0;
    padding: 0.65rem 1.5rem;
    background: rgba(162, 0, 255, 0.2);
    border: 1px solid rgba(162, 0, 255, 0.4);
    border-radius: 8px;
    color: #fff;
    font-size: 0.8rem;
    font-weight: 500;
    font-family: Beiruti, sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
  }
  .expand-btn:hover {
    background: rgba(162, 0, 255, 0.4);
    border-color: rgba(162, 0, 255, 0.6);
  }
  .expand-btn.hidden {
    display: none;
  }
  /* Tarjeta de actor: estilos tomados de elenco.astro */
  .person-card {
    position: relative;
    display: block;
    text-decoration: none !important;
    line-height: 1;
    color: #ffffff;
    width: 100%;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(255, 255, 255, 0.16);
    background: rgba(255, 255, 255, 0.04);
    box-shadow: 0 12px 22px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(6px);
    transition:
      transform 0.35s ease,
      box-shadow 0.35s ease,
      border-color 0.35s ease;
  }
  .person-card:is(:hover, :focus-visible) {
    transform: translateY(-3px);
    box-shadow: 0 18px 32px rgba(0, 0, 0, 0.45);
    border-color: rgba(162, 0, 255, 0.35);
  }
  .person-card:focus-visible {
    outline: 2px solid rgba(255, 215, 255, 0.75);
    outline-offset: 4px;
  }
  .person-card.current {
    opacity: 0.6;
    pointer-events: none;
    border-color: #ffffff;
    /* Mantener tamaño: usar highlight interno y conservar bordes de 1px */
    box-shadow:
      0 0 0 1px #ffffff inset,
      0 12px 22px rgba(0, 0, 0, 0.35);
  }
  .hover-image {
    position: relative;
    display: block;
    width: 100%;
    aspect-ratio: 3 / 4;
    vertical-align: bottom;
    margin: 0;
    overflow: hidden;
