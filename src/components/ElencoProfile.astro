---
const {
  nombre,
  descripcion1 = "",
  descripcion2 = "",
  carpetaGaleria,
  heroImage = null, // ImageMetadata or null
  galeriaImages = [], // ImageMetadata[]
  usernameInstagram = "",
  usernameTikTok = "",
  spotifyUrl = "",
  usernameTwitch = "",
  usernameYoutube = "",
  pageTitle = nombre,
  prevActor = null,
  nextActor = null,
  allActors = [],
  currentSlug = "",
} = Astro.props as {
  // ... types
  nombre: string;
  descripcion1?: string;
  descripcion2?: string;
  carpetaGaleria?: string;
  heroImage?: ImageMetadata | null;
  galeriaImages?: ImageMetadata[];
  usernameInstagram?: string;
  usernameTikTok?: string;
  spotifyUrl?: string;
  usernameTwitch?: string;
  usernameYoutube?: string;
  pageTitle?: string;
  prevActor?: any;
  nextActor?: any;
  allActors?: any[];
  currentSlug?: string;
};

import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";

const gridCardSizes = "(max-width: 600px) 70vw, (max-width: 980px) 33vw, 220px";
const deriveHover = (src: string) => {
  if (!src) return src;
  try {
    return src.replace(/A(\.[a-z0-9]+)$/i, "B$1");
  } catch {
    return src;
  }
};
const firstNamesOnly = (full: string = "") => {
  const parts = (full || "").trim().split(/\s+/);
  if (parts.length <= 1) return full || "";
  return parts.slice(0, parts.length - 1).join(" ");
};
const handles = Array.from(new Set(
  [usernameInstagram, usernameTikTok]
    .filter(Boolean)
    .map(h => h.replace(/^@/, '').toLowerCase())
));

// Preparar foto de hero para cada actor en la navegación
// Preparar foto de hero para cada actor en la navegación
// OJO: allActors es data/elenco.ts (strings).
// Si queremos renderizar sus imagenes con <Image />, deberiamos importarlas dinámicamente o mantener el <img> string based para el grid inferior por ahora
// O idealmente hacer el mismo glob lookup aqui.
// Sin embargo, `allActors` viene como prop.
// Para no romper el grid, vamos a cargar las imagenes via glob aqui tambien para el grid.
const allImagesGrid = import.meta.glob<{ default: ImageMetadata }>(
  "/src/assets/images/elenco/**/*.{webp,avif,png,jpg,jpeg,gif}",
);

const actorsWithHero = await Promise.all(
  allActors.map(async (actor: any) => {
    const heroPathBase = actor.hero.replace(
      /^\/images\/elenco\//,
      "/src/assets/images/elenco/",
    );

    // Buscar en el glob la imagen que coincida
    const heroImageImport = Object.keys(allImagesGrid).find((key) =>
      key.endsWith(heroPathBase.split("/src/assets/images/elenco/")[1]),
    );
    const meta: ImageMetadata | undefined = heroImageImport
      ? (await allImagesGrid[heroImageImport]()).default
      : undefined;

    // Calculamos hover (B version)
    // Reemplazar A.ext por B.ext
    // Asumimos nomenclatura .../algoA.webp -> .../algoB.webp
    let hoverMeta: ImageMetadata | undefined = undefined;
    if (heroImageImport) {
      const hoverKey = heroImageImport.replace(/A(\.[a-z0-9]+)$/i, "B$1");
      if (allImagesGrid[hoverKey]) {
        hoverMeta = (await allImagesGrid[hoverKey]()).default;
      }
    }

    return {
      ...actor,
      heroMeta: meta, // Nuevo campo
      hoverMeta: hoverMeta, // Nuevo campo
      displayName: firstNamesOnly(actor.nombre),
    };
  }),
);
---

<main class="actor-page">
  <article class="actor-card">
    <header class="actor-header">
      <div class="hero-wrap">
        {
          heroImage && (
            <figure class="actor-hero">
              <Image
                src={heroImage}
                alt={`Foto de ${nombre}`}
                loading="eager"
                width={600}
                height={800}
                fetchpriority="high"
                decoding="async"
              />
            </figure>
          )
        }
      </div>
      <div class="info-wrap">
        <h1 class="actor-name">{pageTitle}</h1>
        <section class="actor-bio">
          {
            descripcion1 && (
              <p class="reveal-on-scroll" set:html={descripcion1} />
            )
          }
          {
            descripcion2 && (
              <p class="reveal-on-scroll" set:html={descripcion2} />
            )
          }
        </section>
        {
          (usernameInstagram ||
            usernameTikTok ||
            spotifyUrl ||
            usernameTwitch ||
            usernameYoutube) && (
            <section class="actor-social">
              <h2 class="sr-only">Redes sociales</h2>
              <div class="social-row reveal-on-scroll">
                <span
                  class="handle-rotator"
                  data-handles={JSON.stringify(handles)}
                >
                  {handles.length > 0 ? `@${handles[0]}` : ""}
                </span>
                <div class="social-buttons">
                  {usernameInstagram && (
                    <a
                      href={`https://instagram.com/${usernameInstagram}`}
                      target="_blank"
                      rel="noopener"
                      class="btn-icon"
                      aria-label={`Instagram @${usernameInstagram}`}
                      title={`Instagram @${usernameInstagram}`}
                    >
                      <svg
                        class="icon icon-ig"
                        viewBox="0 0 24 24"
                        width="20"
                        height="20"
                        fill="currentColor"
                      >
                        <path d="M7 2h10a5 5 0 0 1 5 5v10a5 5 0 0 1-5 5H7a5 5 0 0 1-5-5V7a5 5 0 0 1 5-5zm0 2a3 3 0 0 0-3 3v10a3 3 0 0 0 3 3h10a3 3 0 0 0 3-3V7a3 3 0 0 0-3-3H7zm5 3a5 5 0 1 1 0 10 5 5 0 0 1 0-10zm0 2.2a2.8 2.8 0 1 0 0 5.6 2.8 2.8 0 0 0 0-5.6zM18 6.5a1 1 0 1 1 0 2 1 1 0 0 1 0-2z" />
                      </svg>
                    </a>
                  )}
                  {usernameTikTok && (
                    <a
                      href={`https://www.tiktok.com/@${usernameTikTok}`}
                      target="_blank"
                      rel="noopener"
                      class="btn-icon"
                      aria-label={`TikTok @${usernameTikTok}`}
                      title={`TikTok @${usernameTikTok}`}
                    >
                      <svg
                        class="icon icon-tt"
                        viewBox="0 0 16 16"
                        width="16"
                        height="16"
                        fill="currentColor"
                      >
                        <path d="M9 0h1.98c.144.715.54 1.617 1.235 2.512C12.895 3.389 13.797 4 15 4v2c-1.753 0-3.07-.814-4-1.829V11a5 5 0 1 1-5-5v2a3 3 0 1 0 3 3z" />
                      </svg>
                    </a>
                  )}
                  {spotifyUrl && (
                    <a
                      href={spotifyUrl}
                      target="_blank"
                      rel="noopener"
                      class="btn-icon"
                      aria-label={`Spotify de ${nombre}`}
                      title={`Spotify de ${nombre}`}
                    >
                      <svg
                        class="icon icon-spotify"
                        viewBox="0 0 24 24"
                        width="18"
                        height="18"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M12 1.5C6.2 1.5 1.5 6.2 1.5 12S6.2 22.5 12 22.5 22.5 17.8 22.5 12 17.8 1.5 12 1.5zm4.9 14.2c-.2.3-.6.4-.9.2-2.6-1.6-5.9-2-9.8-1.1-.3.1-.7-.1-.8-.4-.1-.3.1-.7.4-.8 4.2-1 7.9-.6 10.8 1.2.3.2.4.6.3.9zm1.2-3.1c-.2.3-.6.5-.9.3-3-1.8-7.5-2.4-11-1.3-.4.1-.8-.1-.9-.5s.1-.8.5-.9c4-1.2 9-0.6 12.4 1.5.3.2.4.6.3.9zm.1-3.3c-3.5-2.1-9.4-2.3-12.8-1.3-.5.1-1-.2-1.1-.7-.1-.5.2-1 .7-1.1 3.9-1.1 10.3-.9 14.3 1.5.5.3.6.9.3 1.4-.3.4-.9.6-1.4.2z" />
                      </svg>
                    </a>
                  )}
                  {usernameTwitch && (
                    <a
                      href={`https://www.twitch.tv/${usernameTwitch}`}
                      target="_blank"
                      rel="noopener"
                      class="btn-icon"
                      aria-label={`Twitch @${usernameTwitch}`}
                      title={`Twitch @${usernameTwitch}`}
                    >
                      <svg
                        class="icon icon-twitch"
                        viewBox="0 0 16 16"
                        width="16"
                        height="16"
                        fill="currentColor"
                        aria-hidden="true"
                      >
                        <path d="M3.857 0 1 2.857v10.286h3.429V16l2.857-2.857H9.57L14.714 8V0H3.857zm9.714 7.429-2.285 2.285H9l-2 2v-2H4.429V1.143h9.142v6.286z" />{" "}
                        <path d="M11.857 3.143h-1.143V6.57h1.143V3.143zm-3.143 0H7.571V6.57h1.143V3.143z" />
                      </svg>
                    </a>
                  )}
                  {usernameYoutube && (
                    <a
                      href={usernameYoutube.startsWith('http') ? usernameYoutube : (usernameYoutube.includes('youtube.com/') || usernameYoutube.includes('youtu.be/') ? `https://${usernameYoutube}` : `https://youtube.com/@${usernameYoutube.replace(/^@/, '')}`)}
                      target="_blank"
                      rel="noopener"
                      class="btn-icon"
                      aria-label={`YouTube @${usernameYoutube}`}
                      title={`YouTube @${usernameYoutube}`}
                    >
                      <svg
                        class="icon icon-youtube"
                        viewBox="0 0 24 24"
                        width="20"
                        height="20"
                        fill="currentColor"
                      >
                        <path d="M21.582 6.186a2.6 2.6 0 0 0-1.83-1.83C18.14 3.93 12 3.93 12 3.93s-6.14 0-7.752.426a2.6 2.6 0 0 0-1.83 1.83C2 7.798 2 12 2 12s0 4.202.418 5.814a2.6 2.6 0 0 0 1.83 1.83C5.86 20.07 12 20.07 12 20.07s6.14 0 7.752-.426a2.6 2.6 0 0 0 1.83-1.83C22 16.202 22 12 22 12s0-4.202-.418-5.814zM9.59 15.56V8.44L15.69 12z"/>
                      </svg>
                    </a>
                  )}
                </div>
              </div>
            </section>
          )
        }
      </div>
    </header>

    <!-- Navegación anterior/siguiente -->
    {
      (prevActor || nextActor) && (
        <nav class="actor-navigation" aria-label="Navegación entre actores">
          {prevActor && (
            <a
              href={`/elenco/${prevActor.slug}`}
              class="nav-actor nav-prev"
              title={`Anterior: ${prevActor.nombre}`}
            >
              <span class="nav-arrow">‹</span>
              <span class="nav-name">{prevActor.nombre}</span>
            </a>
          )}
          {nextActor && (
            <a
              href={`/elenco/${nextActor.slug}`}
              class="nav-actor nav-next"
              title={`Siguiente: ${nextActor.nombre}`}
            >
              <span class="nav-name">{nextActor.nombre}</span>
              <span class="nav-arrow">›</span>
            </a>
          )}
        </nav>
      )
    }

    {
      galeriaImages?.length > 0 && (
        <section
          class="actor-gallery"
          role="region"
          aria-label={`Galería de ${nombre}`}
        >
          <h2>Galería</h2>
          <div class="slider" data-autoplay="true" data-interval="4000">
            <div class="slides">
              {galeriaImages.map((imgMeta: ImageMetadata, i: number) => {
                // Ensure max processed size is 1100x650 (or less if original is smaller)
                // We maintain aspect ratio.
                const MAX_W = 1100;
                const MAX_H = 650;
                const ratio = Math.min(
                  1,
                  MAX_W / imgMeta.width,
                  MAX_H / imgMeta.height,
                );
                const finalW = Math.round(imgMeta.width * ratio);
                const finalH = Math.round(imgMeta.height * ratio);

                return (
                  <figure
                    class={`slide ${i === 0 ? "active" : ""}`}
                    data-index={i}
                  >
                    <div
                      class="slide-bg"
                      style={`background-image: url('${imgMeta.src}')`}
                    />
                    <Image
                      class="slide-img"
                      src={imgMeta}
                      alt={`${nombre} — foto ${i + 1}`}
                      loading={i === 0 ? "eager" : "lazy"}
                      width={finalW}
                      height={finalH}
                      style="width: 100%; height: 100%; object-fit: contain;"
                    />
                  </figure>
                );
              })}
              {/* Slide especial Zona VIP */}
              <figure class="slide slide-vip" data-index={galeriaImages.length}>
                {galeriaImages.length > 0 && (
                  <div
                    class="slide-bg"
                    style={`background-image: url('${galeriaImages[0].src}')`}
                  />
                )}
                <div class="vip-overlay">
                  <div class="vip-content">
                    <svg
                      class="vip-icon"
                      xmlns="http://www.w3.org/2000/svg"
                      viewBox="0 0 24 24"
                      width="48"
                      height="48"
                      fill="none"
                      stroke="currentColor"
                      stroke-width="2"
                      stroke-linecap="round"
                      stroke-linejoin="round"
                    >
                      <rect x="3" y="11" width="18" height="11" rx="2" ry="2" />
                      <path d="M7 11V7a5 5 0 0 1 10 0v4" />
                    </svg>
                    <h3>Contenido restringido</h3>
                    <p>Accede a más imágenes en la Zona VIP</p>
                    <a href="/zona-vip" class="vip-cta-btn">
                      <span>Ir a la Zona VIP</span>
                      <svg
                        xmlns="http://www.w3.org/2000/svg"
                        viewBox="0 0 24 24"
                        width="20"
                        height="20"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2.5"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                      >
                        <path d="M5 12h14M12 5l7 7-7 7" />
                      </svg>
                    </a>
                  </div>
                </div>
              </figure>
            </div>
            <button class="nav prev" aria-label="Anterior" title="Anterior">
              ‹
            </button>
            <button class="nav next" aria-label="Siguiente" title="Siguiente">
              ›
            </button>
            <div class="dots" aria-label="Paginación de la galería">
              {galeriaImages.map((_meta: any, i: number) => (
                <button
                  class={`dot ${i === 0 ? "active" : ""}`}
                  data-index={i}
                  aria-label={`Ver imagen ${i + 1}`}
                />
              ))}
              <button
                class="dot dot-vip"
                data-index={galeriaImages.length}
                aria-label="Zona VIP"
              />
            </div>
          </div>
        </section>
      )
    }
  </article>

  <!-- Sección de todos los actores -->
  {
    allActors.length > 0 && (
      <section
        class="all-actors-section"
        aria-label="Conoce al resto del elenco"
      >
        <h2>Conoce al resto del elenco</h2>
        <div class="actors-grid-wrapper" id="actorsGridWrapper">
          <div class="actors-grid">
            {actorsWithHero.map((actor: any) => (
              <a
                href={`/elenco/${actor.slug}`}
                class={`person-card ${actor.slug === currentSlug ? "current" : ""}`}
                aria-current={actor.slug === currentSlug ? "page" : undefined}
                aria-label={`Ir a ${actor.displayName}`}
              >
                <figure class="hover-image" role="img" aria-hidden="false">
                  {actor.heroMeta ? (
                    <Image
                      class="img-1"
                      src={actor.heroMeta}
                      width={200}
                      alt={actor.nombre}
                      style="width: 100%; height: 100%; object-fit: cover;"
                    />
                  ) : (
                    /* Fallback si no hay imagen (no deberia pasar si los paths estan bien) */
                    <div class="img-fallback" />
                  )}

                  {actor.hoverMeta && (
                    <Image
                      class="img-2"
                      src={actor.hoverMeta}
                      width={200}
                      alt={actor.nombre}
                      loading="lazy"
                      style="width: 100%; height: 100%; object-fit: cover;"
                    />
                  )}
                </figure>
                <div class="person-meta">
                  <p class="person-name">{actor.displayName}</p>
                </div>
              </a>
            ))}
          </div>
        </div>
        <button class="expand-btn" id="expandBtn">
          Ver todos los actores
        </button>
      </section>
    )
  }
</main>

<style>
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .actor-page {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1rem 3rem;
    position: relative;
  }

  /* Navegación anterior/siguiente */
  .actor-navigation {
    display: flex;
    justify-content: space-between;
    gap: 0.75rem;
    margin: 1.5rem 0;
    width: 100%;
  }
  .nav-actor {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.5rem 0.85rem;
    background: rgba(0, 0, 0, 0.6);
    border: 1px solid rgba(255, 255, 255, 0.2);
    border-radius: 8px;
    color: #fff;
    text-decoration: none;
    font-size: 0.85rem;
    font-weight: 500;
    backdrop-filter: blur(8px);
    transition: all 0.25s ease;
    flex: 1;
    max-width: 48%;
  }
  .nav-actor:hover {
    background: rgba(162, 0, 255, 0.7);
    border-color: rgba(162, 0, 255, 0.5);
    transform: scale(1.02);
    color: #ffffff !important;
  }
  .nav-prev {
    flex-direction: row;
    justify-content: flex-start;
  }
  .nav-next {
    flex-direction: row;
    justify-content: flex-end;
    text-align: right;
  }
  .nav-arrow {
    font-size: 1.3rem;
    line-height: 1;
    font-weight: 300;
  }
  .nav-name {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .actor-header {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 1.5rem;
    align-items: start;
  }
  .hero-wrap {
    min-height: 280px;
  }
  .actor-hero {
    margin: 0;
    aspect-ratio: 3 / 4;
    overflow: hidden;
  }
  .actor-hero img {
    width: 100%;
    height: 100%;
    max-height: 800px;
    object-fit: contain;
    display: block;
    border-radius: 14px;
  }
  .info-wrap {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .actor-name {
    margin: 0;
    font-size: 2.4rem;
    line-height: 1.1;
    letter-spacing: 0.3px;
  }
  .actor-bio p {
    margin: 0 0 0.8rem 0;
    font-size: 1.05rem;
    line-height: 1.65;
    text-align: left;
  }
  .social-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .handle-rotator {
    font-weight: 600;
    letter-spacing: 0.2px;
    min-height: 1.2em;
    display: inline-block;
    white-space: nowrap;
    transition: opacity 0.3s ease;
  }
  .social-buttons {
    display: inline-flex;
    gap: 0.5rem;
  }
  .btn-icon {
    width: 36px;
    height: 36px;
    display: inline-grid;
    place-items: center;
    border: 1px solid #ffffff33;
    border-radius: 999px;
    text-decoration: none;
  }
  .btn-icon:hover {
    background: #00000066;
  }
  @media (prefers-reduced-motion: reduce) {
    .handle-rotator {
      transition: none;
    }
  }

  /* Gallery slider */
  .actor-gallery {
    margin-top: 2rem;
  }
  .actor-gallery h2 {
    font-size: 1.3rem;
    margin: 0 0 0.75rem 0;
  }
  .slider {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    background: #111;
  }
  .slider {
    touch-action: pan-y;
    cursor: grab;
  }
  .slider.dragging {
    cursor: grabbing;
  }
  .slides {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 1;
    pointer-events: none;
  }
  .slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    margin: 0;
    overflow: hidden;
  }
  .slide.active {
    opacity: 1;
  }
  .slide-bg {
    position: absolute;
    inset: 0;
    background-position: center;
    background-size: cover;
    filter: blur(18px);
    transform: scale(1.08);
    opacity: 0.7;
  }
  .slide-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }
  .nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: #00000066;
    color: #fff;
    border: 1px solid #ffffff33;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    cursor: pointer;
    backdrop-filter: blur(2px);
    z-index: 3;
    pointer-events: auto;
  }
  .nav:hover {
    background: #00000099;
  }
  .nav.prev {
    left: 10px;
  }
  .nav.next {
    right: 10px;
  }
  .dots {
    position: absolute;
    bottom: 10px;
    left: 0;
    right: 0;
    display: flex;
    justify-content: center;
    gap: 8px;
    z-index: 3;
  }
  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 1px solid #ffffff80;
    background: #ffffff33;
    cursor: pointer;
    padding: 0;
  }
  .dot.active {
    background: #a200ff;
    border-color: #a200ff;
  }
  .dot-vip {
    background: linear-gradient(135deg, #a200ff 0%, #d946ef 100%);
    border-color: #a200ff;
    box-shadow: 0 0 8px rgba(162, 0, 255, 0.6);
    opacity: 0;
    pointer-events: none;
  }
  .dot-vip.active {
    opacity: 1;
  }

  /* Slide especial Zona VIP */
  .slide-vip {
    pointer-events: none;
  }
  .slide-vip .slide-bg {
    filter: blur(25px) brightness(0.85);
    opacity: 1;
  }
  .vip-overlay {
    position: absolute;
    inset: 0;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    background: transparent;
    pointer-events: none;
  }
  .vip-content {
    text-align: center;
    padding: 2rem;
    color: #fff;
    max-width: 450px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(10px);
    border-radius: 20px;
    border: 2px solid rgba(162, 0, 255, 0.4);
    box-shadow:
      0 0 30px rgba(162, 0, 255, 0.3),
      0 0 60px rgba(162, 0, 255, 0.15),
      0 8px 32px rgba(0, 0, 0, 0.4);
    pointer-events: none;
  }
  .vip-cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    margin-top: 1.25rem;
