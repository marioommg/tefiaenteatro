---
import { Image } from "astro:assets";

// Import Elenco images
import albaImg from "../assets/images/elenco/inicio/albaB.webp";
import antonioImg from "../assets/images/elenco/inicio/antonioB.webp";
import moisesImg from "../assets/images/elenco/inicio/moisesB.webp";
import sarakImg from "../assets/images/elenco/inicio/sarakB.webp";
import juanjoImg from "../assets/images/elenco/inicio/juanjoB.webp";
import darioImg from "../assets/images/elenco/inicio/darioB.webp";
import eiderImg from "../assets/images/elenco/inicio/eiderB.webp";
import helenaImg from "../assets/images/elenco/inicio/helenaB.webp";
import nicoImg from "../assets/images/elenco/inicio/nicolasB.webp";

// Import all Vestuario images from the looks directory
const lookImages = import.meta.glob<{ default: ImageMetadata }>(
    "../assets/sobre-el-proyecto/looks/*.{jpg,jpeg,png,webp}",
    { eager: true },
);

// Sort images numerically by their LOOK number (e.g. 1, 2, 4, 13...)
const vestuarioImages = Object.entries(lookImages)
    .sort(([pathA], [pathB]) => {
        const numA = parseInt(pathA.match(/LOOK\s*(\d+)/i)?.[1] || "0");
        const numB = parseInt(pathB.match(/LOOK\s*(\d+)/i)?.[1] || "0");
        return numA - numB;
    })
    .map(([_, mod]) => mod.default);
---

