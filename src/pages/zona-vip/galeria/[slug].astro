  <script is:inline
    type="application/json"
    id="gallery-photo-data"
    set:html={JSON.stringify(galleryItems)}
  />
  <script is:inline>
    // Leer filtros desde la URL en el cliente
    (function () {
      console.log("Reading filters from URL:", window.location.href);
      console.log("Search string:", window.location.search);

      const params = new URLSearchParams(window.location.search);
      const activeFilters = {
        theme: [],
        person: [],
        event: [],
        musical: [],
      };

      // Log todos los parámetros detectados
      params.forEach((value, key) => {
        if (key === "theme") activeFilters.theme.push(value);
        if (key === "person") activeFilters.person.push(value);
        if (key === "event") activeFilters.event.push(value);
        if (key === "musical") activeFilters.musical.push(value);
      });

      // Guardar en elemento para que el otro script lo lea
      const filterDataEl = document.createElement("script");
      filterDataEl.type = "application/json";
      filterDataEl.id = "active-filters-data";
      filterDataEl.textContent = JSON.stringify(activeFilters);
      document.head.appendChild(filterDataEl);

      console.log("Filters from URL:", activeFilters);

      // Actualizar el botón de volver con filtros
      const backLink = document.querySelector(".photo-back-link");
      if (backLink) {
        if (
          activeFilters.theme.length ||
          activeFilters.person.length ||
          activeFilters.event.length ||
          activeFilters.musical.length
        ) {
          const backParams = new URLSearchParams();
          activeFilters.theme.forEach((t) => backParams.append("theme", t));
          activeFilters.person.forEach((p) => backParams.append("person", p));
          activeFilters.event.forEach((e) => backParams.append("event", e));
          activeFilters.musical.forEach((m) => backParams.append("musical", m));
          backLink.setAttribute(
            "href",
            `/zona-vip/galeria/?${backParams.toString()}`,
          );
        } else {
          backLink.setAttribute("href", "/zona-vip/galeria/?nofilter");
        }
      }

      // Si la URL contiene ?nofilter, limpiar filtros y recargar galería limpia
      if (window.location.search.includes("nofilter")) {
        try {
          localStorage.removeItem("vipGalleryFilters");
          sessionStorage.removeItem("vipGalleryFilters");
        } catch {}
        // Si estamos en la galería principal, recargar sin parámetros
        if (window.location.pathname.endsWith("/zona-vip/galeria/")) {
          window.location.replace("/zona-vip/galeria/");
        }
      }
      // Pintar filtros seleccionados y permitir quitarlos en detalle
      const selectedFiltersEl = document.getElementById("selected-filters");
      const photoDataRaw = document.getElementById("gallery-photo-data");
      const photoData =
        photoDataRaw && photoDataRaw.textContent
          ? JSON.parse(photoDataRaw.textContent)
          : [];

      // Construir lookups de etiquetas a partir de los datos disponibles
      const labelMaps = {
        theme: new Map(),
        person: new Map(),
        event: new Map(),
        musical: new Map(),
      };

      try {
        photoData.forEach((it) => {
          if (it.themeSlug)
            labelMaps.theme.set(it.themeSlug, it.theme || it.themeSlug);
          if (Array.isArray(it.peopleSlugs) && Array.isArray(it.people)) {
            it.peopleSlugs.forEach((slug, idx) => {
              const name = it.people[idx] || slug;
              if (slug) labelMaps.person.set(slug, name);
            });
          }
          if (it.eventSlug)
            labelMaps.event.set(it.eventSlug, it.event || it.eventSlug);
          if (it.musicalNumberSlug)
            labelMaps.musical.set(
              it.musicalNumberSlug,
              it.musicalNumber || it.musicalNumberSlug,
            );
        });
      } catch {}

      function buildGalleryUrlFromFilters() {
        const params = new URLSearchParams();
        activeFilters.theme.forEach((t) => params.append("theme", t));
        activeFilters.person.forEach((p) => params.append("person", p));
        activeFilters.event.forEach((e) => params.append("event", e));
        activeFilters.musical.forEach((m) => params.append("musical", m));
        const qs = params.toString();
        return `/zona-vip/galeria/${qs ? "?" + qs : ""}`;
      }

      function renderSelectedFiltersDetail() {
        if (!selectedFiltersEl) return;

        const hasAny =
          activeFilters.theme.length ||
          activeFilters.person.length ||
          activeFilters.event.length ||
          activeFilters.musical.length;
        console.log(
          "[VIP] Filtros activos:",
          JSON.stringify(activeFilters),
          "hasAny:",
          hasAny,
        );
        if (!hasAny) {
          selectedFiltersEl.classList.remove("active");
          selectedFiltersEl.innerHTML =
            '<span style="color:#ccc;font-size:.95em;">(No hay filtros activos)</span>';
          const back = document.querySelector(".photo-back-link");
          if (back) back.setAttribute("href", "/zona-vip/galeria/?nofilter");
          return;
        }
        selectedFiltersEl.classList.add("active");
        selectedFiltersEl.innerHTML = "";

        const addChip = (type, slug) => {
          const chip = document.createElement("span");
          chip.className = "selected-filter";
          let label = slug;
          try {
            if (type === "theme") label = labelMaps.theme.get(slug) || slug;
            else if (type === "person")
              label = labelMaps.person.get(slug) || slug;
            else if (type === "event")
              label = labelMaps.event.get(slug) || slug;
            else if (type === "musical")
              label = labelMaps.musical.get(slug) || slug;
          } catch {}
          chip.textContent = label;

          const btn = document.createElement("button");
          btn.className = "remove-filter";
          btn.type = "button";
          btn.setAttribute("aria-label", `Quitar filtro: ${label}`);
          btn.textContent = "×";
          btn.addEventListener("click", () => {
            // Eliminar del estado local
            if (type === "theme")
              activeFilters.theme = activeFilters.theme.filter(
                (v) => v !== slug,
              );
            if (type === "person")
              activeFilters.person = activeFilters.person.filter(
                (v) => v !== slug,
              );
            if (type === "event")
              activeFilters.event = activeFilters.event.filter(
                (v) => v !== slug,
              );
            if (type === "musical")
              activeFilters.musical = activeFilters.musical.filter(
                (v) => v !== slug,
              );

            // Actualizar href del botón volver
            const back = document.querySelector(".photo-back-link");
            if (back) back.setAttribute("href", buildGalleryUrlFromFilters());

            // Actualizar navegación y URL actual (si el script posterior define helpers, se actualizarán después)
            try {
              const currentSlug = window.location.pathname
                .split("/")
                .filter(Boolean)
                .pop();
              if (currentSlug) {
                const params = new URLSearchParams();
                activeFilters.theme.forEach((t) => params.append("theme", t));
                activeFilters.person.forEach((p) => params.append("person", p));
                activeFilters.event.forEach((e) => params.append("event", e));
                activeFilters.musical.forEach((m) =>
                  params.append("musical", m),
                );
                const qs = params.toString();
                const newUrl = `/zona-vip/galeria/${currentSlug}/${qs ? "?" + qs : ""}`;
                window.history.replaceState({}, "", newUrl);
              }
            } catch {}

            // Re-render chips
            renderSelectedFiltersDetail();

            // Emitir evento para que otros scripts (navegación) puedan reaccionar si lo desean
            document.dispatchEvent(
              new CustomEvent("vip:filters-changed", {
                detail: { activeFilters },
              }),
            );
          });

          chip.appendChild(btn);
          selectedFiltersEl.appendChild(chip);
        };

        activeFilters.theme.forEach((slug) => addChip("theme", slug));
        activeFilters.event.forEach((slug) => addChip("event", slug));
        activeFilters.person.forEach((slug) => addChip("person", slug));
        activeFilters.musical.forEach((slug) => addChip("musical", slug));

        // Actualizar el enlace de volver con los filtros actuales
        const back = document.querySelector(".photo-back-link");
        if (back) back.setAttribute("href", buildGalleryUrlFromFilters());
      }

      renderSelectedFiltersDetail();
    })();
  </script>
  <script is:inline>
    (function () {
      // Función para convertir WebP a JPG y descargar
      async function downloadAsJPG(webpUrl, filename, button) {
        const originalText = button ? button.textContent : "";

        try {
          if (button) {
            button.disabled = true;
            button.innerHTML =
              '<svg viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false" class="spinner" style="display:inline-block;margin-right:0.5rem;"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="3" fill="none" opacity="0.25"/><path fill="currentColor" d="M12 2a10 10 0 0 1 10 10h-3a7 7 0 0 0-7-7V2z"/></svg>Descargando...';
          }

          const img = new Image();
          img.crossOrigin = "anonymous";

          await new Promise((resolve, reject) => {
            img.onload = resolve;
            img.onerror = reject;
            img.src = webpUrl;
          });

          const canvas = document.createElement("canvas");
          canvas.width = img.naturalWidth;
          canvas.height = img.naturalHeight;

          const ctx = canvas.getContext("2d");
          if (!ctx) {
            if (button) {
              button.disabled = false;
              button.textContent = originalText;
            }
            return;
          }
          ctx.drawImage(img, 0, 0);

          canvas.toBlob(
            (blob) => {
              if (!blob) {
                if (button) {
                  button.disabled = false;
                  button.textContent = originalText;
                }
                return;
              }

              const url = URL.createObjectURL(blob);
              const a = document.createElement("a");
              a.href = url;
              a.download = filename.replace(/\.webp$/i, ".jpg");
              document.body.appendChild(a);
              a.click();
              document.body.removeChild(a);
              URL.revokeObjectURL(url);

              if (button) {
                button.disabled = false;
                button.textContent = originalText;
              }
            },
            "image/jpeg",
            0.95,
          );
        } catch (error) {
          console.error("Error:", error);
          if (button) {
            button.disabled = false;
            button.textContent = originalText;
          }
          window.open(webpUrl, "_blank");
        }
      }

      function initDownload() {
        const root = document.querySelector(".photo-info");
        if (!root) return;

        root.addEventListener("click", function (e) {
          const btn = e.target.closest(".download-link");
          if (!btn || !btn.hasAttribute("data-download-src")) return;
          e.preventDefault();
          const src = btn.getAttribute("data-download-src");
          const file = btn.getAttribute("data-download-file");
          if (src && file) {
            downloadAsJPG(src, file, btn);
          }
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initDownload);
      } else {
        initDownload();
      }
    })();
  </script>
  <script is:inline>
    // SPA-like navigation for photo detail con filtros preservados
    document.addEventListener("DOMContentLoaded", function () {
      const photoDataRaw = document.getElementById("gallery-photo-data");
      const photoData =
        photoDataRaw && photoDataRaw.textContent
          ? JSON.parse(photoDataRaw.textContent)
          : [];
      const activeFiltersRaw = document.getElementById("active-filters-data");

      let activeFilters = { theme: [], person: [], event: [], musical: [] };

      if (activeFiltersRaw && activeFiltersRaw.textContent) {
        try {
          const parsed = JSON.parse(activeFiltersRaw.textContent);
          console.log("Parsed filters from JSON:", parsed);
          activeFilters = parsed || activeFilters;
        } catch (e) {
          console.error("Error parsing filters:", e);
        }
      }

      console.log("Active filters loaded:", activeFilters);

      // Re-render filtros seleccionados si llegan cambios de otro bloque
      document.addEventListener("vip:filters-changed", (e) => {
        try {
          const detail = e.detail || {};
          if (detail.activeFilters) {
            activeFilters = detail.activeFilters;
            const currentSlug = window.location.pathname
              .split("/")
              .filter(Boolean)
              .pop();
            if (currentSlug) updateNavigationButtons(currentSlug);
          }
        } catch {}
      });

      const navButtons = document.querySelectorAll(".photo-nav-button");
      const photoImg = document.getElementById("vip-photo-img");
      const photoMeta = document.querySelector(".photo-meta");
      const modal = document.getElementById("vip-photo-modal");
      const modalImg = modal
        ? modal.querySelector(".vip-photo-modal-img")
        : null;
      const modalBg = modal ? modal.querySelector(".vip-photo-modal-bg") : null;

      // Filtrar fotos según los filtros activos
      function getFilteredPhotos() {
        const hasFilters =
          activeFilters.theme.length ||
          activeFilters.person.length ||
          activeFilters.event.length ||
          activeFilters.musical.length;

        if (!hasFilters) {
          return photoData;
        }

        return photoData.filter((item) => {
          if (
            activeFilters.theme.length &&
            !activeFilters.theme.includes(item.themeSlug)
          ) {
            return false;
          }

          if (activeFilters.person.length) {
            const hasMatchingPerson = item.peopleSlugs.some((slug) =>
              activeFilters.person.includes(slug),
            );
            if (!hasMatchingPerson) return false;
          }

          if (
            activeFilters.event.length &&
            !activeFilters.event.includes(item.eventSlug)
          ) {
            return false;
          }

          if (
            activeFilters.musical.length &&
            !activeFilters.musical.includes(item.musicalNumberSlug)
          ) {
            return false;
          }

          return true;
        });
      }

      // Construir URL con filtros preservados
      function buildUrlWithFilters(slug) {
        const params = new URLSearchParams();

        // Agregar todos los filtros activos
        if (activeFilters.theme && activeFilters.theme.length > 0) {
          activeFilters.theme.forEach((t) => params.append("theme", t));
        }
        if (activeFilters.person && activeFilters.person.length > 0) {
          activeFilters.person.forEach((p) => params.append("person", p));
        }
        if (activeFilters.event && activeFilters.event.length > 0) {
          activeFilters.event.forEach((e) => params.append("event", e));
        }
        if (activeFilters.musical && activeFilters.musical.length > 0) {
          activeFilters.musical.forEach((m) => params.append("musical", m));
        }

        const queryStr = params.toString();
        return `/zona-vip/galeria/${slug}/${queryStr ? "?" + queryStr : ""}`;
      }

      // Actualizar botones de navegación basándose en filtros
      function updateNavigationButtons(currentSlug) {
        const filteredPhotos = getFilteredPhotos();
        const currentIndex = filteredPhotos.findIndex(
          (entry) => entry.slug === currentSlug,
        );
        const prevItem =
          currentIndex > 0 ? filteredPhotos[currentIndex - 1] : null;
        const nextItem =
          currentIndex >= 0 && currentIndex < filteredPhotos.length - 1
            ? filteredPhotos[currentIndex + 1]
            : null;

        console.log("Navigation update:", {
          currentSlug,
          currentIndex,
          filteredCount: filteredPhotos.length,
          prevItem: prevItem?.slug,
          nextItem: nextItem?.slug,
        });

        navButtons.forEach((btn) => {
          if (btn instanceof HTMLElement) btn.style.display = "none";
        });

        if (prevItem) {
          const prevBtn = document.querySelector(".photo-nav-button--prev");
          if (prevBtn && prevBtn instanceof HTMLAnchorElement) {
            prevBtn.setAttribute("href", buildUrlWithFilters(prevItem.slug));
            prevBtn.setAttribute("data-target-slug", prevItem.slug);
            prevBtn.setAttribute(
              "aria-label",
              `Ver fotografía anterior: ${prevItem.alt}`,
            );
            prevBtn.style.display = "";
          }
        }

        if (nextItem) {
          const nextBtn = document.querySelector(".photo-nav-button--next");
          if (nextBtn && nextBtn instanceof HTMLAnchorElement) {
            nextBtn.setAttribute("href", buildUrlWithFilters(nextItem.slug));
            nextBtn.setAttribute("data-target-slug", nextItem.slug);
            nextBtn.setAttribute(
              "aria-label",
              `Ver fotografía siguiente: ${nextItem.alt}`,
            );
            nextBtn.style.display = "";
          }
        }
      }

      // Obtener slug actual de la URL
      const currentSlug = window.location.pathname
        .split("/")
        .filter(Boolean)
        .pop();

      // Actualizar navegación al cargar
      if (currentSlug) {
        updateNavigationButtons(currentSlug);
      }

      // También actualizar el enlace de volver al cargar en base a activeFilters
      (function updateBackLinkOnLoad() {
        const backLink = document.querySelector(".photo-back-link");
        if (!backLink) return;
        const params = new URLSearchParams();
        activeFilters.theme.forEach((t) => params.append("theme", t));
        activeFilters.person.forEach((p) => params.append("person", p));
        activeFilters.event.forEach((e) => params.append("event", e));
        activeFilters.musical.forEach((m) => params.append("musical", m));
        backLink.setAttribute(
          "href",
          `/zona-vip/galeria/${params.toString() ? "?" + params.toString() : ""}`,
        );
      })();

      function updatePhoto(slug) {
        const item = photoData.find((entry) => entry.slug === slug);
        if (!item) return;

        // Update image
        if (photoImg) {
          photoImg.setAttribute("src", item.src);
          photoImg.setAttribute("alt", item.alt);
          photoImg.setAttribute("width", String(item.width));
          photoImg.setAttribute("height", String(item.height));
          photoImg.setAttribute("tabindex", "0");
          photoImg.setAttribute("loading", "eager");
          photoImg.setAttribute("decoding", "async");
        }

        // Update meta
        if (photoMeta) {
          // Limpiar el contenedor
          photoMeta.innerHTML = "";

          // Personas
          const personasRow = document.createElement("div");
          personasRow.className = "photo-meta-row photo-meta-row--clickable";
          personasRow.innerHTML = "<dt>Personas</dt>";
          const personasDD = document.createElement("dd");

          if (item.people && item.people.length > 0) {
            const peopleList = document.createElement("ul");
            peopleList.className = "photo-people";
            item.people.forEach((person, idx) => {
              const li = document.createElement("li");
              const a = document.createElement("a");
              a.href = `/zona-vip/galeria/?person=${item.peopleSlugs[idx]}`;
              a.className = "meta-button-person";
              a.textContent = person;
              li.appendChild(a);
              peopleList.appendChild(li);
            });
            personasDD.appendChild(peopleList);
          } else {
            personasDD.textContent = "No especificado";
          }

          personasRow.appendChild(personasDD);
          photoMeta.appendChild(personasRow);

          // Fecha de captura
          if (item.date) {
            let dateStr = item.date;
            try {
              const parts = item.date.split(' ');
              if (parts.length === 2) {
                const dateParts = parts[0].split(':');
                const timeParts = parts[1].split(':');
                if (dateParts.length === 3) {
                  dateStr = `${dateParts[2]}/${dateParts[1]}/${dateParts[0]} ${timeParts[0]}:${timeParts[1]}`;
                }
              }
            } catch (e) {}

            const dateRow = document.createElement("div");
            dateRow.className = "photo-meta-row photo-meta-row--pair";
            const dateCell = document.createElement("div");
            dateCell.className = "photo-meta-cell";
            dateCell.innerHTML = "<dt>Fecha de captura</dt><dd>" + dateStr + "</dd>";
            const emptyCell = document.createElement("div");
            emptyCell.className = "photo-meta-cell";
            emptyCell.setAttribute("aria-hidden", "true");
            dateRow.appendChild(dateCell);
            dateRow.appendChild(emptyCell);
            photoMeta.appendChild(dateRow);
          }

          // Evento + Temática + Descargar (misma fila)
          const eventThemeRow = document.createElement("div");
          eventThemeRow.className =
            "photo-meta-row photo-meta-row--pair photo-meta-row--with-actions";

          const eventCell = document.createElement("div");
          eventCell.className = "photo-meta-cell photo-meta-cell--clickable";
          const eventDt = document.createElement("dt");
          eventDt.textContent = "Evento";
          const eventDd = document.createElement("dd");
          if (item.event && item.eventSlug) {
            const eventoA = document.createElement("a");
            eventoA.href = `/zona-vip/galeria/?event=${item.eventSlug}`;
            eventoA.className = "meta-button meta-button--event";
            eventoA.textContent = item.event;
            eventDd.appendChild(eventoA);
          } else {
            eventDd.textContent = "No especificado";
          }
          eventCell.appendChild(eventDt);
          eventCell.appendChild(eventDd);

          const themeCell = document.createElement("div");
          themeCell.className = "photo-meta-cell";
          themeCell.setAttribute("aria-hidden", "true");

          const downloadCell = document.createElement("div");
          downloadCell.className = "photo-meta-cell photo-meta-cell--action";
          const downloadDt = document.createElement("dt");
          downloadDt.className = "sr-only";
          downloadDt.textContent = "Descargar";
          const downloadDd = document.createElement("dd");
          downloadDd.className = "photo-meta-action-dd";
          const downloadBtn = document.createElement("button");
          downloadBtn.type = "button";
          downloadBtn.id = "vip-photo-download";
          downloadBtn.className = "download-link";
          downloadBtn.setAttribute("data-download-src", item.src);
          downloadBtn.setAttribute("data-download-file", item.file);
          downloadBtn.setAttribute("aria-label", "Descargar fotografía en JPG");
          downloadBtn.innerHTML =
            '<svg class="photo-meta-action-icon" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false"><path fill="currentColor" d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path></svg> Descargar';
          downloadDd.appendChild(downloadBtn);
          downloadCell.appendChild(downloadDt);
          downloadCell.appendChild(downloadDd);

          eventThemeRow.appendChild(eventCell);
          eventThemeRow.appendChild(themeCell);
          eventThemeRow.appendChild(downloadCell);
          photoMeta.appendChild(eventThemeRow);

          // Número musical
          if (item.musicalNumber) {
            const musicalRow = document.createElement("div");
            musicalRow.className = "photo-meta-row photo-meta-row--clickable";
            musicalRow.innerHTML = "<dt>Número musical</dt>";
            const musicalDD = document.createElement("dd");
            const musicalA = document.createElement("a");
            musicalA.href = `/zona-vip/galeria/?musical=${item.musicalNumberSlug}`;
            musicalA.className = "meta-button meta-button--musical";
            musicalA.textContent = item.musicalNumber;
            musicalDD.appendChild(musicalA);
            musicalRow.appendChild(musicalDD);
            photoMeta.appendChild(musicalRow);
          }

          // Archivo + Dimensiones + Reportar (misma fila)
          const fileDimRow = document.createElement("div");
          fileDimRow.className =
            "photo-meta-row photo-meta-row--pair photo-meta-row--with-actions";

          const archivoCell = document.createElement("div");
          archivoCell.className = "photo-meta-cell";
          const archivoDt = document.createElement("dt");
          archivoDt.textContent = "Archivo";
          const archivoDD = document.createElement("dd");
          archivoDD.className = "photo-meta-file";
          archivoDD.textContent = item.file;
          archivoCell.appendChild(archivoDt);
          archivoCell.appendChild(archivoDD);

          const dimCell = document.createElement("div");
          dimCell.className = "photo-meta-cell";
          const dimDt = document.createElement("dt");
          dimDt.textContent = "Dimensiones";
          const dimDD = document.createElement("dd");
          dimDD.textContent = item.width + " × " + item.height + "px";
          dimCell.appendChild(dimDt);
          dimCell.appendChild(dimDD);

          const reportCell = document.createElement("div");
          reportCell.className = "photo-meta-cell photo-meta-cell--action";
          const reportDt = document.createElement("dt");
          reportDt.className = "sr-only";
          reportDt.textContent = "Pedir un cambio";
          const reportDd = document.createElement("dd");
          reportDd.className = "photo-meta-action-dd";
          const reportBtn = document.createElement("button");
          reportBtn.type = "button";
          reportBtn.id = "vip-photo-report";
          reportBtn.className = "report-link";
          reportBtn.setAttribute("data-photo-slug", item.slug);
          reportBtn.setAttribute("aria-label", "Pedir un cambio para esta fotografía");
          reportBtn.innerHTML =
            '<svg class="photo-meta-action-icon photo-meta-action-icon--flag" viewBox="0 0 24 24" width="18" height="18" aria-hidden="true" focusable="false" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"></path><line x1="4" x2="4" y1="22" y2="15"></line></svg> Pedir un cambio';
          reportDd.appendChild(reportBtn);
          reportCell.appendChild(reportDt);
          reportCell.appendChild(reportDd);

          fileDimRow.appendChild(archivoCell);
          fileDimRow.appendChild(dimCell);
          fileDimRow.appendChild(reportCell);
          photoMeta.appendChild(fileDimRow);
        }

        // Update modal image
        if (modalImg) {
          modalImg.setAttribute("src", item.src);
          modalImg.setAttribute("alt", item.alt);
        }

        // Update navigation buttons based on FILTERED photos
        const filteredPhotos = getFilteredPhotos();
        const currentIndex = filteredPhotos.findIndex(
          (entry) => entry.slug === slug,
        );
        const prevItem =
          currentIndex > 0 ? filteredPhotos[currentIndex - 1] : null;
        const nextItem =
          currentIndex >= 0 && currentIndex < filteredPhotos.length - 1
            ? filteredPhotos[currentIndex + 1]
            : null;

        navButtons.forEach((btn) => {
          if (btn instanceof HTMLElement) btn.style.display = "none";
        });

        if (prevItem) {
          const prevBtn = document.querySelector(".photo-nav-button--prev");
          if (prevBtn && prevBtn instanceof HTMLAnchorElement) {
            prevBtn.setAttribute("href", buildUrlWithFilters(prevItem.slug));
            prevBtn.setAttribute("data-target-slug", prevItem.slug);
            prevBtn.setAttribute(
              "aria-label",
              `Ver fotografía anterior: ${prevItem.alt}`,
            );
            prevBtn.style.display = "";
          }
        }

        if (nextItem) {
          const nextBtn = document.querySelector(".photo-nav-button--next");
          if (nextBtn && nextBtn instanceof HTMLAnchorElement) {
            nextBtn.setAttribute("href", buildUrlWithFilters(nextItem.slug));
            nextBtn.setAttribute("data-target-slug", nextItem.slug);
            nextBtn.setAttribute(
              "aria-label",
              `Ver fotografía siguiente: ${nextItem.alt}`,
            );
            nextBtn.style.display = "";
          }
        }

        // Actualiza la URL sin recargar, preservando los parámetros
        const newUrl = buildUrlWithFilters(slug);
        window.history.replaceState({}, "", newUrl);
      }

      navButtons.forEach(function (btn) {
        btn.addEventListener("click", function (e) {
          e.preventDefault();
          const targetSlug = btn.getAttribute("data-target-slug");

          console.log("Navigation clicked:", targetSlug);
          console.log("Current filters:", activeFilters);
          console.log("Filtered photos count:", getFilteredPhotos().length);

          if (typeof targetSlug === "string" && targetSlug) {
            // Actualiza en la misma página (SPA) y preserva la URL con filtros
            updatePhoto(targetSlug);
          }
        });
      });

      // Modal logic
      function openModal() {
        if (modal) {
          modal.setAttribute("aria-hidden", "false");
          document.body.style.overflow = "hidden";
        }
      }

      function closeModal() {
        if (modal) {
          modal.setAttribute("aria-hidden", "true");
          document.body.style.overflow = "";
        }
      }

      if (photoImg) {
        photoImg.addEventListener("click", openModal);
        photoImg.addEventListener("keydown", (e) => {
          if (e.key === "Enter" || e.key === " ") openModal();
        });
      }

      if (modalBg) {
        modalBg.addEventListener("click", closeModal);
      }

      if (modalImg) {
        modalImg.addEventListener("click", closeModal);
      }

      window.addEventListener("keydown", (e) => {
        if (
          modal &&
          modal.getAttribute("aria-hidden") === "false" &&
          (e.key === "Escape" || e.key === "Esc")
        ) {
          closeModal();
        }
      });

    });
  </script>
