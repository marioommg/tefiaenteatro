---
import Layout from "../../../layouts/Layout.astro";
import { galleryItems } from "../../../data/galeria";

export function getStaticPaths() {
  return galleryItems.map((entry) => ({
    params: { slug: entry.slug },
  }));
}

const { slug } = Astro.params;

const item = galleryItems.find((entry) => entry.slug === slug);

if (!item) {
  throw Astro.redirect("/zona-vip/galeria/");
}

// En páginas estáticas, los query params no están disponibles en el servidor
// Los leeremos en el cliente
const activeFiltersPlaceholder = {
  theme: [] as string[],
  person: [] as string[],
  event: [] as string[],
  musical: [] as string[],
};

// Función para filtrar items
function filterItems(items: typeof galleryItems) {
  // En el servidor no tenemos acceso a los query params en páginas estáticas
  // El filtrado se hará en el cliente
  return items;
}

// No filtrar en el servidor - se hará en el cliente
const filteredItems = galleryItems;

// Encontrar índice - se calculará en el cliente con los filtros correctos
const currentIndex = galleryItems.findIndex(
  (entry: (typeof galleryItems)[number]) => entry.slug === item.slug,
);
const prevItem = currentIndex > 0 ? galleryItems[currentIndex - 1] : null;
const nextItem =
  currentIndex >= 0 && currentIndex < galleryItems.length - 1
    ? galleryItems[currentIndex + 1]
    : null;

// Construir query string preservando filtros
const buildUrlWithFilters = (itemSlug: string) => {
  // Las URLs se construirán en el cliente
  return `/zona-vip/galeria/${itemSlug}/`;
};

const pageTitle = `Zona VIP – Fotografía ${item.id}`;
const pageDescription =
  "Fotografía de la galería exclusiva de Tefía en el teatro.";
const eventLabel = item.event ? item.event : null;
const hasEvent = !!item.event;
const musicalNumberLabel = item.musicalNumber ? item.musicalNumber : null;
const hasMusicalNumber = !!item.musicalNumber;
const hasPeople = item.people.length > 0;
const dimensionLabel = `${item.width} × ${item.height}px`;

const dateLabel = item.date ? (() => {
  try {
    const parts = item.date.split(' ');
    if (parts.length === 2) {
      const dateParts = parts[0].split(':');
      const timeParts = parts[1].split(':');
      if (dateParts.length === 3) {
        return `${dateParts[2]}/${dateParts[1]}/${dateParts[0]} ${timeParts[0]}:${timeParts[1]}`;
      }
    }
  } catch (e) {}
  return item.date;
})() : null;
const hasDate = !!item.date;

// Construir URL de retorno - se hará en el cliente
const backUrl = "/zona-vip/galeria/";

const apiUrl = import.meta.env.PUBLIC_REVISION_API_URL || "";
const photoReportAuth = import.meta.env.PHOTO_REPORT_SECRET || "";
---

<Layout
  title={pageTitle}
  description={pageDescription}
  noContainer="true"
  robots="noindex, nofollow"
>
  <script is:inline define:vars={{ apiUrl, photoReportAuth }}>
    window.__REVISION_API_URL__ = apiUrl;
    window.__PHOTO_REPORT_AUTH__ = photoReportAuth;
  </script>
  <main class="vip-photo-detail">
    <nav class="photo-detail-nav" aria-label="Navegación secundaria">
      <a class="photo-back-link" href={backUrl}>
        <span class="photo-back-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="18" height="18" focusable="false">
            <path
              fill="currentColor"
              d="M15.71 5.29a1 1 0 0 0-1.42 0L7.88 11.7a1 1 0 0 0 0 1.42l6.41 6.41a1 1 0 1 0 1.42-1.42L10.41 12l5.3-5.29a1 1 0 0 0 0-1.42z"
            ></path>
          </svg>
        </span>
        <span class="photo-back-label">Volver a la galería</span>
      </a>
      <!-- Filtros seleccionados (editable en detalle) -->
      <div class="selected-filters" id="selected-filters"></div>
    </nav>

    <article class="photo-detail-card">
      <div class="photo-visual">
        <img
          src={item.src}
          alt={item.alt}
          width={item.width}
          height={item.height}
          loading="eager"
          decoding="async"
          class="vip-photo-img"
          id="vip-photo-img"
          tabindex="0"
        />
        <a
          class="photo-nav-button photo-nav-button--prev"
          href={prevItem ? buildUrlWithFilters(prevItem.slug) : "#"}
          aria-label={prevItem
            ? `Ver fotografía anterior: ${prevItem.alt}`
            : "Ver fotografía anterior"}
          data-photo-nav="prev"
          data-target-slug={prevItem ? prevItem.slug : ""}
          style={prevItem ? "" : "display: none;"}
        >
          <svg
            viewBox="0 0 24 24"
            width="28"
            height="28"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M15.71 5.29a1 1 0 0 0-1.42 0L7.88 11.7a1 1 0 0 0 0 1.42l6.41 6.41a1 1 0 1 0 1.42-1.42L10.41 12l5.3-5.29a1 1 0 0 0 0-1.42z"
            ></path>
          </svg>
        </a>

        <a
          class="photo-nav-button photo-nav-button--next"
          href={nextItem ? buildUrlWithFilters(nextItem.slug) : "#"}
          aria-label={nextItem
            ? `Ver fotografía siguiente: ${nextItem.alt}`
            : "Ver fotografía siguiente"}
          data-photo-nav="next"
          data-target-slug={nextItem ? nextItem.slug : ""}
          style={nextItem ? "" : "display: none;"}
        >
          <svg
            viewBox="0 0 24 24"
            width="28"
            height="28"
            aria-hidden="true"
            focusable="false"
          >
            <path
              fill="currentColor"
              d="M8.29 5.29a1 1 0 0 1 1.42 0L16.12 11.7a1 1 0 0 1 0 1.42l-6.41 6.41a1 1 0 1 1-1.42-1.42L13.59 12l-5.3-5.29a1 1 0 0 1 0-1.42z"
            ></path>
          </svg>
        </a>
      </div>

      <div class="photo-info">
        <h1 class="sr-only">Fotografía</h1>
        <dl class="photo-meta">
          <div class="photo-meta-row photo-meta-row--clickable">
            <dt>Personas</dt>
            <dd>
              {
                hasPeople ? (
                  <ul class="photo-people">
                    {item.people.map((person, index) => (
                      <li>
                        <a
                          href={`/zona-vip/galeria/?person=${item.peopleSlugs[index]}`}
                          class="meta-button-person"
                        >
                          {person}
                        </a>
                      </li>
                    ))}
                  </ul>
                ) : (
                  "No especificado"
                )
              }
            </dd>
          </div>
          <div class="photo-meta-row photo-meta-row--pair photo-meta-row--with-actions">
            <div class="photo-meta-cell photo-meta-cell--clickable">
              <dt>Evento</dt>
              <dd>
                {
                  hasEvent ? (
                    <a
                      href={`/zona-vip/galeria/?event=${item.eventSlug}`}
                      class="meta-button meta-button--event"
                    >
                      {eventLabel}
                    </a>
                  ) : (
                    "No especificado"
                  )
                }
              </dd>
            </div>
            <div class="photo-meta-cell" aria-hidden="true">
              <!-- Temática oculta -->
            </div>
            <div class="photo-meta-cell photo-meta-cell--action">
              <dt class="sr-only">Descargar</dt>
              <dd class="photo-meta-action-dd">
                <button
                  type="button"
                  id="vip-photo-download"
                  class="download-link"
                  data-download-src={item.src}
                  data-download-file={item.file}
                  aria-label="Descargar fotografía en JPG"
                >
                  <svg
                    class="photo-meta-action-icon"
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    aria-hidden="true"
                    focusable="false"
                    ><path
                      fill="currentColor"
                      d="M19 9h-4V3H9v6H5l7 7 7-7zM5 18v2h14v-2H5z"></path></svg
                  >
                  Descargar
                </button>
              </dd>
            </div>
          </div>
          {
            hasMusicalNumber && (
              <div class="photo-meta-row photo-meta-row--clickable">
                <dt>Número musical</dt>
                <dd>
                  <a
                    href={`/zona-vip/galeria/?musical=${item.musicalNumberSlug}`}
                    class="meta-button meta-button--musical"
                  >
                    {musicalNumberLabel}
                  </a>
                </dd>
              </div>
            )
          }
          {
            hasDate && (
              <div class="photo-meta-row photo-meta-row--pair">
                <div class="photo-meta-cell">
                  <dt>Fecha de captura</dt>
                  <dd>{dateLabel}</dd>
                </div>
                <div class="photo-meta-cell" aria-hidden="true"></div>
              </div>
            )
          }
          <div class="photo-meta-row photo-meta-row--pair photo-meta-row--with-actions">
            <div class="photo-meta-cell">
              <dt>Archivo</dt>
              <dd class="photo-meta-file">{item.file}</dd>
            </div>
            <div class="photo-meta-cell">
              <dt>Dimensiones</dt>
              <dd>{dimensionLabel}</dd>
            </div>
            <div class="photo-meta-cell photo-meta-cell--action">
              <dt class="sr-only">Pedir un cambio</dt>
              <dd class="photo-meta-action-dd">
                <button
                  type="button"
                  id="vip-photo-report"
                  class="report-link"
                  data-photo-slug={item.slug}
                  aria-label="Pedir un cambio para esta fotografía"
                >
                  <svg
                    class="photo-meta-action-icon photo-meta-action-icon--flag"
                    viewBox="0 0 24 24"
                    width="18"
                    height="18"
                    aria-hidden="true"
                    focusable="false"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    ><path d="M4 15s1-1 4-1 5 2 8 2 4-1 4-1V3s-1 1-4 1-5-2-8-2-4 1-4 1z"
                    ></path><line x1="4" x2="4" y1="22" y2="15"></line></svg
                  >
                  Pedir un cambio
                </button>
              </dd>
            </div>
          </div>
        </dl>
      </div>
    </article>
  </main>

  <!-- Fullscreen photo modal -->
  <div
    id="vip-photo-modal"
    class="vip-photo-modal"
    tabindex="-1"
    aria-hidden="true"
  >
    <div class="vip-photo-modal-bg"></div>
    <img src={item.src} alt={item.alt} class="vip-photo-modal-img" />
  </div>

  <!-- Modal de Pedir un cambio -->
  <div
    id="vip-report-modal"
    class="vip-report-modal"
    tabindex="-1"
    aria-hidden="true"
  >
    <div class="vip-report-modal-bg"></div>
    
    <!-- Paso 1: Elegir opción -->
    <div class="vip-report-modal-content" id="report-step-1">
      <div class="vip-report-modal-header">
        <h2>Pedir un cambio</h2>
        <button type="button" class="vip-report-modal-close" aria-label="Cerrar">&times;</button>
      </div>
      <div class="vip-report-modal-body">
        <p>¿Qué tipo de cambio quieres solicitar para esta imagen?</p>
        <div class="vip-report-options">
          <button type="button" class="vip-report-option-btn" id="btn-opt-modify">
            <strong>Modificar información</strong>
            <span>Personas, evento o temática incorrecta</span>
          </button>
          <button type="button" class="vip-report-option-btn vip-report-option-btn--danger" id="btn-opt-delete">
            <strong>Borrar imagen</strong>
            <span>Pedir que se retire esta fotografía</span>
          </button>
        </div>
      </div>
    </div>

    <!-- Paso 2: Modificar información -->
    <div class="vip-report-modal-content" id="report-step-modify" style="display: none;">
      <div class="vip-report-modal-header">
        <h2>Modificar información</h2>
        <button type="button" class="vip-report-modal-close" aria-label="Cerrar">&times;</button>
      </div>
      <div class="vip-report-modal-body">
        <div class="form-group">
          <label for="modify-people">Personas</label>
          <input type="text" id="modify-people" placeholder="Ej: Fulanito, Menganito..." />
        </div>
        <div class="form-group row-group">
          <div class="form-col">
            <label for="modify-event">Evento</label>
            <input type="text" id="modify-event" placeholder="Ej: Estreno" />
          </div>
          <div class="form-col" style="display: none;">
            <label for="modify-theme">Temática</label>
            <input type="text" id="modify-theme" placeholder="Ej: Backstage" />
          </div>
        </div>
        <div class="form-group">
          <label for="modify-music">Número musical</label>
          <input type="text" id="modify-music" placeholder="Ej: Canción Inicial" />
        </div>
        <div class="form-group" style="margin-top: -0.5rem; margin-bottom: 1rem;">
          <label style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; color: #fff; font-size: 0.95rem; font-weight: normal; margin-bottom: 0;">
            <input type="checkbox" id="modify-rotate" style="width: auto; cursor: pointer; margin: 0;" />
            La imagen sale girada, hay que rotarla
          </label>
        </div>
        <div class="form-group">
          <label for="modify-extra" style="color: #999; font-size: 0.85rem; font-weight: normal;">Comentarios adicionales (opcional)</label>
          <textarea id="modify-extra" rows="2" placeholder="Explica cualquier otro dato incorrecto..."></textarea>
        </div>
        <div class="vip-report-actions">
          <button type="button" class="vip-report-back-btn">Atrás</button>
          <button type="button" class="vip-report-submit-btn">Enviar petición</button>
        </div>
      </div>
    </div>

    <!-- Paso 3: Borrar imagen -->
    <div class="vip-report-modal-content" id="report-step-delete" style="display: none;">
      <div class="vip-report-modal-header">
        <h2>Borrar imagen</h2>
        <button type="button" class="vip-report-modal-close" aria-label="Cerrar">&times;</button>
      </div>
      <div class="vip-report-modal-body">
        <div class="form-group">
          <label>Motivo por el que deseas retirarla:</label>
          <textarea rows="4" placeholder="Explícanos por qué..."></textarea>
        </div>
        <div class="vip-report-actions">
          <button type="button" class="vip-report-back-btn">Atrás</button>
          <button type="button" class="vip-report-submit-btn vip-report-submit-btn--danger">Pedir borrado</button>
        </div>
      </div>
    </div>

    <!-- Paso 4: Éxito -->
    <div class="vip-report-modal-content" id="report-step-success" style="display: none; text-align: center;">
      <div class="vip-report-modal-header" style="justify-content: center; border-bottom: none;">
        <h2 style="margin: 0;">¡Recibido!</h2>
      </div>
      <div class="vip-report-modal-body">
        <p style="color: #fff; font-size: 1.1rem;">Tu petición ha sido enviada con éxito.</p>
        <p style="margin-bottom: 2rem;">La revisaremos a la mayor brevedad posible.</p>
        <button type="button" class="vip-report-submit-btn vip-report-modal-close-final" style="width: 100%;">Cerrar</button>
      </div>
    </div>
  </div>

  <script is:inline>
    (function() {
      function initReportModal() {
        const modal = document.getElementById("vip-report-modal");
        const bg = modal ? modal.querySelector(".vip-report-modal-bg") : null;
        const closeBtn = modal ? modal.querySelector(".vip-report-modal-close") : null;
        const options = modal ? modal.querySelectorAll(".vip-report-option-btn") : [];
        
        function open(btnNode) {
          if (modal) {
            modal.setAttribute("aria-hidden", "false");
            document.body.style.overflow = "hidden";
            showStep("report-step-1"); // Reset a paso inicial al abrir
            
            // Populate inputs
            const slug = btnNode ? btnNode.getAttribute("data-photo-slug") : null;
            if (slug) {
              const photoDataRaw = document.getElementById("gallery-photo-data");
              const photoData = photoDataRaw && photoDataRaw.textContent ? JSON.parse(photoDataRaw.textContent) : [];
              const item = photoData.find(e => e.slug === slug);
              
              if (item) {
                const inputPeople = modal.querySelector("#modify-people");
                const inputEvent = modal.querySelector("#modify-event");
                const inputTheme = modal.querySelector("#modify-theme");
                const inputMusic = modal.querySelector("#modify-music");
                const inputRotate = modal.querySelector("#modify-rotate");
                
                if (inputPeople) inputPeople.value = (item.people || []).join(", ");
                if (inputEvent) inputEvent.value = item.event || "";
                if (inputTheme) inputTheme.value = item.theme || "";
                if (inputMusic) inputMusic.value = item.musicalNumber || "";
                if (inputRotate) inputRotate.checked = false;
              }
            }

            // Restablecer textareas
            modal.querySelectorAll('textarea').forEach(t => t.value = '');
          }
        }
        
        function close() {
          if (modal) {
            modal.setAttribute("aria-hidden", "true");
            document.body.style.overflow = "";
          }
        }

        function showStep(stepId) {
           const steps = modal.querySelectorAll('.vip-report-modal-content');
           steps.forEach(s => s.style.display = 'none');
           const target = modal.querySelector('#' + stepId);
           if (target) {
              target.style.display = 'block';
           }
        }

        document.addEventListener("click", function(e) {
          const btn = e.target.closest("#vip-photo-report");
          if (btn) {
            e.preventDefault();
            open(btn);
          }
        });

        // Botones de cierre
        if (bg) bg.addEventListener("click", close);
        const closeBtns = modal ? modal.querySelectorAll(".vip-report-modal-close, .vip-report-modal-close-final") : [];
        closeBtns.forEach(btn => btn.addEventListener("click", close));
        
        // Navegación del modal
        const btnModify = modal ? modal.querySelector("#btn-opt-modify") : null;
        const btnDelete = modal ? modal.querySelector("#btn-opt-delete") : null;
        const btnBacks = modal ? modal.querySelectorAll(".vip-report-back-btn") : [];
        const btnSubmits = modal ? modal.querySelectorAll(".vip-report-submit-btn:not(.vip-report-modal-close-final)") : [];

        if (btnModify) btnModify.addEventListener("click", () => showStep("report-step-modify"));
        if (btnDelete) btnDelete.addEventListener("click", () => showStep("report-step-delete"));
        btnBacks.forEach(b => b.addEventListener("click", () => showStep("report-step-1")));
        btnSubmits.forEach(b => b.addEventListener("click", async () => {
           b.disabled = true;
           b.textContent = "Procesando...";

           const isDanger = b.classList.contains('vip-report-submit-btn--danger');
           const actionStr = isDanger ? 'delete' : 'modify';
           const activePhotoSlug = document.querySelector("#vip-photo-report")?.getAttribute("data-photo-slug");
           
           const photoDataRaw = document.getElementById("gallery-photo-data");
           const photoDataList = photoDataRaw && photoDataRaw.textContent ? JSON.parse(photoDataRaw.textContent) : [];
           const photoItem = photoDataList.find(e => e.slug === activePhotoSlug) || {};

           const payload = {
              type: "photo_report",
              action: actionStr,
              photoSlug: activePhotoSlug,
              file: photoItem.file || "Desconocido",
              data: {}
           };

           if (actionStr === 'modify') {
              payload.data = {
                 people: modal.querySelector("#modify-people")?.value,
                 event: modal.querySelector("#modify-event")?.value,
                 theme: modal.querySelector("#modify-theme")?.value,
                 music: modal.querySelector("#modify-music")?.value,
                 rotateImage: modal.querySelector("#modify-rotate")?.checked ? "Sí" : "No",
                 extra: modal.querySelector("#modify-extra")?.value
              };
           } else {
              payload.data = {
                 reason: modal.querySelector("#report-step-delete textarea")?.value
              };
           }

           const endpoint = window.__REVISION_API_URL__ || "";

           try {
             const res = await fetch(endpoint, {
                method: "POST",
                headers: {
                  "Content-Type": "application/json",
                  "X-Report-Auth": window.__PHOTO_REPORT_AUTH__ || "",
                },
                body: JSON.stringify(payload)
             });
             
             if (!res.ok) throw new Error("Network error");
             
             b.disabled = false;
             b.textContent = isDanger ? "Pedir borrado" : "Enviar petición";
             showStep("report-step-success");
           } catch (err) {
             console.error("Error submitting report:", err);
             b.disabled = false;
             b.textContent = isDanger ? "Pedir borrado" : "Enviar petición";
             alert("Hubo un problema de conexión. Por favor, inténtalo de nuevo.");
           }
        }));

        window.addEventListener("keydown", (e) => {
          if (modal && modal.getAttribute("aria-hidden") === "false" && (e.key === "Escape" || e.key === "Esc")) {
            close();
          }
        });
      }

      if (document.readyState === "loading") {
        document.addEventListener("DOMContentLoaded", initReportModal);
      } else {
        initReportModal();
      }
    })();
  </script>

  <link rel="stylesheet" href="/styles/ampliacion-galeria.css" />
  <style is:global>
    .vip-photo-detail {
      max-width: 1200px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem 4rem;
      color: #fff;
      display: flex;
      flex-direction: column;
      gap: 2rem;
    }
    .photo-back-link {
      display: inline-flex;
      align-items: center;
      gap: 0.6rem;
      text-decoration: none;
      font-weight: 600;
      letter-spacing: 0.01em;
      padding: 0.6rem 1.2rem;
      border-radius: 0.85rem;
      color: #fff;
      background: linear-gradient(
        135deg,
        rgba(162, 0, 255, 0.18),
        rgba(90, 0, 200, 0.12)
      );
      border: 1px solid rgba(162, 0, 255, 0.35);
      box-shadow: 0 12px 28px rgba(0, 0, 0, 0.35);
      transition:
        transform 0.18s ease,
        box-shadow 0.18s ease,
        border-color 0.18s ease,
        background 0.18s ease;
    }
    .photo-back-link:hover {
      transform: translateY(-2px);
      box-shadow: 0 18px 34px rgba(0, 0, 0, 0.42);
      border-color: rgba(162, 0, 255, 0.6);
      background: linear-gradient(
        135deg,
        rgba(162, 0, 255, 0.28),
        rgba(90, 0, 200, 0.18)
      );
      color: #fff;
    }
    .photo-back-link:focus-visible {
      outline: 2px solid rgba(162, 0, 255, 0.85);
      outline-offset: 3px;
    }
    .photo-back-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 1.9rem;
      height: 1.9rem;
      border-radius: 999px;
      background: rgba(0, 0, 0, 0.25);
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: inset 0 0 0 1px rgba(255, 255, 255, 0.06);
    }
    .photo-back-label {
      white-space: nowrap;
    }
    .photo-detail-card {
      display: flex;
      flex-direction: column;
      align-items: stretch;
      gap: 2.2rem;
      width: 100%;
      max-width: 100%;
      box-sizing: border-box;
    }
    /* Marco 4:3 fijo: la altura NO depende de la imagen. La img va en absolute (no aporta min-content). */
    .photo-visual {
      position: relative;
      width: 100%;
      min-width: 0;
      box-sizing: border-box;
      background: #050505;
      border-radius: 22px;
      overflow: hidden;
      box-shadow: 0 40px 80px rgba(0, 0, 0, 0.45);
      aspect-ratio: 4 / 3;
      display: block;
    }
