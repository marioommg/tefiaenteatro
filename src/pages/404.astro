---
import PopupAviso from '../components/PopupAviso.astro';
---

<!doctype html>
<html lang="es-ES">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=1" />
        <title>404 — Página no encontrada</title>
        <meta name="robots" content="noindex" />
        <link rel="icon" type="image/webp" href="/favicon.webp" />
        <script is:inline>
            (function() {
                var path = window.location.pathname;
                if (path.startsWith('/zona-vip') && path !== '/zona-vip' && path !== '/zona-vip/') {
                    window.location.replace('/zona-vip/?redirect=' + encodeURIComponent(path));
                }
            })();
        </script>
        <link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=BBH+Sans+Bartle&family=Beiruti:wght@200..900&family=Literata:ital,opsz,wght@0,7..72,200..900;1,7..72,200..900&display=swap" rel="stylesheet">

    </head>
    <body>
        <!-- canvas de partículas -->
        <canvas id="particles" class="particles-canvas" aria-hidden="true"></canvas>

        <div class="wrap">
            <main class="card" role="main" aria-labelledby="title">
                <h1 id="title">Página no encontrada - 404</h1>
                <p>No encontramos esta página. El enlace puede estar roto o tu sesión no está activa.</p>
                <p>¿Buscabas algo exclusivo? Accede a la <a href="/zona-vip" class="inline-link">Zona VIP</a>.</p>

                <div class="actions" role="navigation" aria-label="404 actions">
                    <a class="button" href="/">Ir a la página de inicio</a>
                    <a class="button" href="/zona-vip">Ir a Zona VIP <span aria-label="VIP" title="VIP" class="vip-icon vip-gold">⚡</span></a>
                    <a class="ghost" href="javascript:history.back()">Atrás</a>
                </div>

                <footer>
                    Revisa la URL o escribe si persiste el error.
                </footer>
            </main>
        </div>

        <script is:inline>
            // @ts-nocheck
            // Partículas sencillas, rendimiento adaptativo
            (function (){
                const canvas = document.getElementById('particles');
                const ctx = canvas.getContext('2d');
                let particles = [];
                let width = 0, height = 0, dpr = Math.max(1, window.devicePixelRatio || 1);

                function resize(){
                    width = window.innerWidth;
                    height = window.innerHeight;
                    canvas.width = Math.floor(width * dpr);
                    canvas.height = Math.floor(height * dpr);
                    canvas.style.width = width + 'px';
                    canvas.style.height = height + 'px';
                    ctx.setTransform(dpr,0,0,dpr,0,0);
                    initParticles();
                }

                function initParticles(){
                    // cantidad adaptativa: menos en móvil
                    const base = Math.max(25, Math.round((width * height) / 80000));
                    const targetCount = Math.min(120, base);
                    particles = [];
                    for (let i = 0; i < targetCount; i++) {
                        particles.push(createParticle());
                    }
                }

                function createParticle(){
                    const speed = 0.15 + Math.random() * 0.6;
                    const angle = Math.random() * Math.PI * 2;
                    return {
                        x: Math.random() * width,
                        y: Math.random() * height,
                        vx: Math.cos(angle) * speed,
                        vy: Math.sin(angle) * speed * 0.6,
                        r: 0.8 + Math.random() * 2.6,
                        hue: 260 + Math.random() * 60,
                        alpha: 0.25 + Math.random() * 0.7
                    };
                }

                function step(){
                    ctx.clearRect(0,0,width,height);

                    // draw connections first (subtle)
                    for (let i = 0; i < particles.length; i++) {
                        const a = particles[i];
                        for (let j = i + 1; j < particles.length; j++) {
                            const b = particles[j];
                            const dx = a.x - b.x;
                            const dy = a.y - b.y;
                            const dist = Math.sqrt(dx*dx + dy*dy);
                            if (dist < 120) {
                                const alpha = (1 - dist / 120) * 0.08;
                                ctx.strokeStyle = `rgba(150,90,255,${alpha})`;
                                ctx.lineWidth = 1;
                                ctx.beginPath();
                                ctx.moveTo(a.x, a.y);
                                ctx.lineTo(b.x, b.y);
                                ctx.stroke();
                            }
                        }
                    }

                    // draw particles
                    for (let p of particles){
                        p.x += p.vx;
                        p.y += p.vy;

                        // wrap around
                        if (p.x < -20) p.x = width + 20;
                        if (p.x > width + 20) p.x = -20;
                        if (p.y < -20) p.y = height + 20;
                        if (p.y > height + 20) p.y = -20;

                        // glow
                        ctx.beginPath();
                        ctx.fillStyle = `rgba(255,255,255,${p.alpha})`;
                        const grad = ctx.createRadialGradient(p.x, p.y, 0, p.x, p.y, p.r * 8);
                        grad.addColorStop(0, `hsla(${p.hue}, 95%, 70%, ${p.alpha})`);
                        grad.addColorStop(0.4, `hsla(${p.hue}, 80%, 55%, ${p.alpha * 0.45})`);
                        grad.addColorStop(1, `rgba(0,0,0,0)`);
                        ctx.fillStyle = grad;
                        ctx.arc(p.x, p.y, p.r * 6, 0, Math.PI * 2);
                        ctx.fill();

                        ctx.beginPath();
                        ctx.fillStyle = `rgba(255,255,255,${Math.min(0.9, p.alpha + 0.15)})`;
                        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
                        ctx.fill();
                    }

                    requestAnimationFrame(step);
                }

                let running = true;
                function onVisibility(){
                    running = !document.hidden;
                    if (running) requestAnimationFrame(step);
                }

                window.addEventListener('resize', debounce(resize, 200));
                document.addEventListener('visibilitychange', onVisibility);

                function debounce(fn, t){
                    let id;
                    return (...a)=>{ clearTimeout(id); id = setTimeout(()=>fn(...a), t); }
                }

                // init
                resize();
                requestAnimationFrame(step);
            })();
        </script>
        <PopupAviso />
    </body>
    <style>
            :root{
                --bg:#000000;
                --card:#230a36;
                --accent:#9728ff;
                --muted:#9aa4b2;
            }
            html,body{height:100%}
            body{
                margin:0;
                font-family: Beiruti, ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, "Helvetica Neue", Arial;
                background:linear-gradient(180deg,var(--bg) 0%, #071020 100%);
                color: #e6eef6;
                -webkit-font-smoothing:antialiased;
                -moz-osx-font-smoothing:grayscale;
                font-size: 130%;
            }

            /* Particles canvas sits behind content */
            .particles-canvas{
                position:fixed;
                inset:0;
                width:100%;
                height:100%;
                z-index:0;
                pointer-events:none;
            }

            .wrap{
                min-height:100vh;
                display:flex;
                align-items:center;
                justify-content:center;
                padding:2rem;
                position:relative; /* ensure above canvas */
                z-index:1;
            }
            .card{
                max-width:720px;
                width:100%;
                background:rgb(15 15 15 / 82%);
                border:1px solid rgba(255,255,255,0.04);
                padding:2.5rem;
                border-radius:12px;
                box-shadow:0 6px 30px rgba(2,6,23,0.6);
            }
            h1{
                margin:0 0 .5rem 0;
                font-size:clamp(1.8rem, 4vw, 2.6rem);
                letter-spacing:-0.02em;
            }
            p{
                margin:0 0 1.25rem 0;
                color:var(--muted);
                line-height:1.5;
            }
            .inline-link{ color:#cbb6ff; text-underline-offset: 3px; }
            .actions{
                display:flex;
                gap:.75rem;
                flex-wrap:wrap;
            }
            a.button{
                display:inline-flex;
                align-items:center;
                gap:.6rem;
                text-decoration:none;
                padding:.6rem .9rem;
                border-radius:8px;
                color:white;
                font-weight:600;
                box-shadow:0 6px 18px rgba(255,122,89,0.12);
                background:linear-gradient(90deg,var(--accent),#4e09bd);
                transition: transform 0.18s, box-shadow 0.18s, filter 0.18s;
            }
            a.button:hover {
                transform: scale(1.07) translateY(-2px);
                box-shadow:0 10px 24px rgba(122,89,255,0.18),0 0 0 2px #fff2;
                filter: brightness(1.08);
            }
            a.button[href="/zona-vip"] {
                background: linear-gradient(90deg, #ffd700 60%, #e2b100 100%);
                color: #230a36;
                box-shadow: 0 6px 18px rgba(255,215,0,0.18);
            }
            a.button[href="/zona-vip"]:hover {
                box-shadow:0 10px 24px rgba(255,215,0,0.22),0 0 0 2px #fff2;
                filter: brightness(1.12);
            }
            a.button[href="/zona-vip"] {
                background: linear-gradient(90deg, #ffd700 60%, #e2b100 100%);
                color: #230a36;
                box-shadow: 0 6px 18px rgba(255,215,0,0.18);
            }
            a.button[href="/zona-vip"] {
                background: linear-gradient(90deg, #ffd700 60%, #e2b100 100%);
                color: #230a36;
                box-shadow: 0 6px 18px rgba(255,215,0,0.18);
            }
            .vip-icon {
                font-size:1.1em;
                margin-left:0.3em;
                vertical-align:middle;
                transition: transform 0.18s, filter 0.18s;
                cursor: pointer;
            }
            a.button[href="/zona-vip"]:hover .vip-icon {
                transform: scale(1.18) rotate(-18deg);
                filter: drop-shadow(0 0 8px #ffd700) brightness(1.22);
            }
            .vip-gold {
                color: #ffd700;
                filter: drop-shadow(0 0 2px #ffd700);
            }
            a.ghost{
                background:transparent;
                border:1px solid rgba(255,255,255,0.06);
                color:var(--muted);
                font-weight:600;
                padding:.55rem .85rem;
            }
            footer{
                margin-top:1.25rem;
                color:var(--muted);
                font-size:.9rem;
            }
            @media (max-width:520px){
                .card{padding:1.5rem}
            }
        </style>
</html>