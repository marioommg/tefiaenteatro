# URL de la Lambda photo-report (Function URL)
PUBLIC_REVISION_API_URL=<your-photo-report-lambda-url>
# Secreto Lambda (PHOTO_REPORT_SECRET) y build del sitio (PUBLIC_PHOTO_REPORT_AUTH) — mismo valor
PHOTO_REPORT_SECRET=<random-64-hex-chars>
PUBLIC_PHOTO_REPORT_AUTH=<same-as-PHOTO_REPORT_SECRET>
SES_SENDER_EMAIL=contacto@tefiaenteatro.com
SES_REGION=eu-north-1
VIP_PASSWORD_HASH=<your-bcrypt-hash>
CLOUDFLARE_API_TOKEN=<your-cloudflare-token>
CLOUDFLARE_ZONE_IDS=<your-zone-id>
PUBLIC_VIP_VIDEO_6_JULIO_ID=<youtube-video-id>
